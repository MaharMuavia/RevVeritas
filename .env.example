# ---- RevVeritas environment ----
# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# Google Gemini API key — the agent reasoning model runs on Gemini via the
# google-genai SDK. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model id used for agent function-calling / judgment.
GEMINI_MODEL=gemini-2.5-flash

# Confidence threshold (Guardrail 2). Findings below this are routed to the
# "needs human review" bucket and excluded from the headline recovery total.
REVVERITAS_CONFIDENCE_THRESHOLD=0.6

# Paths (defaults are fine for local dev).
REVVERITAS_DB_URL=sqlite:///revveritas.db
REVVERITAS_TRACE_FILE=traces/agent_trace.jsonl

# FastAPI backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend → backend base URL (used by the Next.js dashboard)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
